name: Subtitle Downloader

on:
  workflow_dispatch:
    inputs:
      url:
        description: 'Video URL'
        required: true
        type: string
      lang:
        description: 'Subtitle language'
        required: false
        default: 'fa'
        type: string

jobs:
  download_subtitle:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install yt-dlp

      - name: Download Persian subtitle as SRT
        run: |
          yt-dlp \
            --skip-download \
            --write-subs \
            --write-auto-subs \
            --sub-langs "${{ github.event.inputs.lang }}" \
            --convert-subs srt \
            -o "%(title)s.%(ext)s" \
            "${{ github.event.inputs.url }}"

      - name: Upload subtitles
        uses: actions/upload-artifact@v4
        with:
          name: subtitles
          path: "*.srt"
